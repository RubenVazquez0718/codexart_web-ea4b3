---
// src/pages/nosotros.astro
import Layout from "../layouts/Layout.astro";

// Valores de la marca personal.
const valores = [
    {
        icon: "fa-solid fa-bullseye",
        title: "Soluciones a la medida",
        text: "Cada empresa es distinta. Construyo herramientas que se ajustan a tu forma de trabajar, no al revés.",
    },
    {
        icon: "fa-solid fa-code",
        title: "Código limpio y mantenible",
        text: "Arquitecturas simples y bien pensadas, optimizadas para el rendimiento y fáciles de hacer crecer.",
    },
    {
        icon: "fa-solid fa-gauge-high",
        title: "Calidad y disponibilidad",
        text: "Lo que antes vivía en hojas de Excel, ahora corre en línea, disponible 24/7 los 365 días del año.",
    },
    {
        icon: "fa-solid fa-handshake",
        title: "Cercanía y acompañamiento",
        text: "Trato directo de principio a fin: tú hablas con quien diseña y desarrolla tu proyecto.",
    },
];
---

<Layout title="Nosotros">
    <!-- Hero -->
    <section class="about-section">
        <h1>Acerca de Codexart</h1>
        <p>Innovación y calidad en desarrollo de software</p>
    </section>

    <!-- Presentación de la marca personal -->
    <section class="max-w-6xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
            <h2 class="text-3xl mb-4">Hola, soy Rubén Vázquez</h2>
            <h4 class="text-brand-600 font-semibold mb-6">Fundador de Codexart · Desarrollador Full Stack</h4>

            <p class="mb-4">
                Codexart es mi marca personal, nacida en Tabasco, México, con una idea clara:
                acercar la tecnología a los pequeños y medianos negocios con soluciones hechas a la medida.
            </p>
            <p class="mb-4">
                Soy desarrollador Full Stack especializado en software empresarial (SaaS), sistemas ERP y
                automatización de procesos administrativos para empresas mexicanas. Trabajo principalmente con
                el ecosistema .NET (C#), Angular y TypeScript, cuidando que cada sistema sea rápido, escalable
                y fácil de mantener.
            </p>
            <p class="mb-6">
                A lo largo de mi trabajo he desarrollado sistemas administrativos, financieros y contables:
                desde paneles con indicadores y reportes, hasta conciliaciones bancarias e integración con el
                SAT para la descarga y visualización de CFDI. Esa experiencia con la parte fiscal y financiera
                de las empresas es la que pongo a tu disposición a través de Codexart.
            </p>

            <span class="font-semibold text-lg block mb-6">"Si puedes imaginarlo... puedes programarlo."</span>

            <a href="/contactanos" class="cdx-button">
                <i class="fa-solid fa-up-right-from-square mr-2"></i>
                Trabajemos juntos
            </a>
        </div>

        <div>
            <img
                src="/ruben.jpg"
                alt="Rubén Vázquez, fundador de Codexart, en su oficina"
                class="w-full h-auto rounded-2xl shadow shadow-brand-200 border border-slate-200 object-cover"
            />
        </div>
    </section>

    <!-- Valores -->
    <section class="bg-gray-50 px-8 py-16">
        <h2 class="text-center text-3xl mb-12">Cómo trabajo</h2>
        <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {
                valores.map((valor) => (
                    <div class="bg-white rounded-lg border border-slate-200 shadow shadow-brand-200 p-6 text-center">
                        <i class={valor.icon + " text-3xl text-brand-600 mb-4"}></i>
                        <h3 class="font-semibold mb-2">{valor.title}</h3>
                        <p class="text-gray-600 text-sm">{valor.text}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Misión -->
    <section class="max-w-4xl mx-auto px-8 py-16 text-center">
        <h2 class="text-3xl mb-4">Mi misión</h2>
        <p class="text-lg text-gray-600">
            Proporcionar soluciones de software de alta calidad que impulsen la transformación digital de
            mis clientes, ayudándoles a alcanzar sus objetivos de negocio a través de la tecnología.
        </p>
    </section>
</Layout>